{
	"compilerOptions": {
		"target": "ES2022",
		"useDefineForClassFields": true,
		"module": "ESNext",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"skipLibCheck": true,
		"composite": true,
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"outDir": "./dist",
		"jsx": "preserve",
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,

		/* Linting */
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"paths": {
			"@client/*": ["./src/client/*"],
			"@tsculpt": ["./src/core"],
			"@tsculpt/*": ["./src/core/*"],
			"@meta": ["./src/meta.ts"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts", "e2e", "example"]
}
